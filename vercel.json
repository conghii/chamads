{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "backend/api/index.ts"
        },
        {
            "source": "/(.*)",
            "destination": "frontend/$1"
        }
    ],
    "redirects": [
        {
            "source": "/",
            "destination": "/frontend/index.html",
            "permanent": false
        }
    ]
}